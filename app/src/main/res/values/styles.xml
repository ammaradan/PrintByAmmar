<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">@color/colorPaper</item>
        <item name="android:statusBarColor">@color/colorHeader</item>
    </style>
    <style name="SectionLabel">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/colorMuted</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="OptionLabel">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/colorInk</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
</resources>
