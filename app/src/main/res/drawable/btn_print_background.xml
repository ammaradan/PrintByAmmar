<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape><solid android:color="#1446b8"/><corners android:radius="16dp"/></shape>
    </item>
    <item android:state_enabled="false">
        <shape><solid android:color="@color/colorMuted"/><corners android:radius="16dp"/></shape>
    </item>
    <item>
        <shape><solid android:color="@color/colorPrimary"/><corners android:radius="16dp"/></shape>
    </item>
</selector>
